flowchart TB
    subgraph Data Sources [📡 DATA SOURCES]
        BTS((BTS Public Data<br/>CSV files))
    end

    subgraph Ingestion [🚀 INGESTION]
        ADF[Azure Data Factory<br/>or Synapse Pipeline]
    end

    subgraph Storage_RAW [💾 BRONZE LAYER - Raw]
        RAW[(Raw CSV/Parquet)]
    end

    subgraph Transformation [⚡ TRANSFORMATION]
        DF[Synapse Mapping Data Flow]
    end

    subgraph Storage_CURATED [💎 SILVER LAYER - Curated]
        CURATED[(Cleaned Parquet)]
    end

    subgraph Compute [🧠 COMPUTE & MODELING]
        SQL_Pool[Dedicated SQL Pool<br/>Gold Layer]
        subgraph Star_Schema [⭐ STAR SCHEMA]
            DIM_DATE[dim_date]
            DIM_AIRLINE[dim_airline]
            DIM_AIRPORT[dim_airport]
            FACT[fact_flights]
        end
    end

    subgraph Serving [📊 SERVING]
        POWERBI[Power BI Dashboard]
    end

    subgraph Orchestration_Monitoring [⏰ ORCHESTRATION & MONITORING]
        TRIGGER[Schedule Trigger<br/>Daily 02:00 UTC]
        MONITOR[Azure Monitor<br/>Alerts]
    end

    BTS -->|HTTP / Upload| ADF
    ADF -->|Copy Activity| RAW
    RAW -->|Data Flow| DF
    DF -->|Write| CURATED
    CURATED -->|COPY INTO| SQL_Pool
    SQL_Pool -->|Star Schema Joins| POWERBI
    TRIGGER -->|Starts| ADF
    MONITOR -->|Metrics & Logs| ADF
    MONITOR -.->|Failure Alerts| POWERBI

